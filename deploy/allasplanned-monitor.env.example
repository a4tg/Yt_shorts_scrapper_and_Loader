# Copy this file to /etc/allasplanned-monitor.env and set permissions to 600.
# Never commit the real Telegram token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

AAP_MONITOR_NAME="All As Planned production"
AAP_MONITOR_HEALTH_URL="https://allasplanned.ru/api/health/ready"
AAP_MONITOR_TIMEOUT_SECONDS=15
AAP_MONITOR_FAILURE_THRESHOLD=3
AAP_MONITOR_REMINDER_FAILURES=60

# Keep false on the independent external monitoring server.
# Set true on production to additionally check Docker and local backup freshness.
AAP_MONITOR_LOCAL_CHECKS=false
AAP_MONITOR_PROJECT_DIR="/opt/yt-loader"
AAP_MONITOR_BACKUP_DIR="/var/backups/yt-loader"
AAP_MONITOR_BACKUP_MAX_AGE_HOURS=36
