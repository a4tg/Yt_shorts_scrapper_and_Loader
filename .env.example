POSTGRES_PASSWORD=replace-with-a-url-safe-random-password
YT_LOADER_SECURE_COOKIES=true
YT_LOADER_ALLOWED_HOSTS=shorts.example.com,localhost,127.0.0.1
YT_LOADER_ENABLE_API_DOCS=false
YT_LOADER_SESSION_DAYS=14
YT_LOADER_ALLOW_REGISTRATION=true
YT_LOADER_TRIAL_DAYS=7
YT_LOADER_SIGNUP_CREDITS=20
YT_LOADER_MAX_OVERLAY_MB=256
YT_LOADER_MAX_CONTENT_FILE_MB=250
YT_LOADER_PREVIEW_MAX_WIDTH=1920
YT_LOADER_PREVIEW_CRF=24
YT_LOADER_PREVIEW_PRESET=veryfast
YT_LOADER_FEATURE_WORKSPACE_DEPTH_SHELL=true
YT_LOADER_FEATURE_CHAT_ANYWHERE=true
YT_LOADER_FEATURE_ASSET_VIEWER=true
YT_LOADER_FEATURE_ASSET_REVIEWS=true
YT_LOADER_FEATURE_PROJECT_GRAPH=true
YT_LOADER_FEATURE_DECISION_INTELLIGENCE=true
YOUTUBE_COOKIES=/cookies/www.youtube.com_cookies.txt
VK_COOKIES=/cookies/vk.com_cookies.txt
RUTUBE_COOKIES=/cookies/rutube.ru_cookies.txt
YT_LOADER_JOB_LEASE_SECONDS=120
YT_LOADER_JOB_POLL_SECONDS=0.5
YT_LOADER_MIN_FREE_DISK_MB=2048
YT_LOADER_METRICS_TOKEN=
YT_LOADER_PUBLIC_BASE_URL=https://shorts.example.com
YT_LOADER_REQUIRE_EMAIL_VERIFICATION=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=All As Planned <no-reply@allasplanned.ru>
YT_LOADER_RENEWAL_INTERVAL_SECONDS=3600
YT_LOADER_WEBHOOK_RETENTION_DAYS=90
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_ENFORCE_IP=true
YOOKASSA_RECEIPT_ENABLED=false
YOOKASSA_VAT_CODE=1
# Payments remain disabled until all legal seller fields are filled and reviewed.
YT_LOADER_ENABLE_PAYMENTS=false
YT_LOADER_REQUIRE_LEGAL_ACCEPTANCE=true
YT_LOADER_LEGAL_SELLER_NAME=
YT_LOADER_LEGAL_SELLER_INN=
YT_LOADER_LEGAL_SELLER_ADDRESS=
YT_LOADER_LEGAL_SUPPORT_EMAIL=support@allasplanned.ru
YT_LOADER_LEGAL_VERSION=2026-07-17
# Set true only after the owner or legal adviser approves the published texts.
YT_LOADER_LEGAL_DOCUMENTS_APPROVED=false
YT_LOADER_LEGACY_BASIC_AUTH=false
YT_LOADER_USERNAME=admin
YT_LOADER_PASSWORD=
FFMPEG_PRESET=veryfast
FFMPEG_CRF=22
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_PREMIUM_TEXT_MODEL=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
# whisper-1 is intentional: clip selection needs segment timestamps.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_TIMESTAMP_MODE=provider
OPENAI_AUDIO_CHUNK_SECONDS=2700
OPENAI_TIMESTAMP_FALLBACK_CHUNK_SECONDS=300

# Recommended launch profile for the OpenAI-compatible AI Tunnel gateway.
# These values take precedence over the legacy OPENAI_* variables above.
AAP_AI_PROVIDER=aitunnel
AAP_AI_API_KEY=
AAP_AI_BASE_URL=https://api.aitunnel.ru/v1
# auto tries Responses first and falls back to Chat Completions when unsupported.
AAP_AI_API_MODE=auto
AAP_AI_FEATURES=text,image,transcription,clips
AAP_AI_TEXT_MODEL=deepseek-v4-flash
# Used only when a strict clip plan from the economical model is invalid.
AAP_AI_PREMIUM_TEXT_MODEL=gpt-5.4-mini
AAP_AI_IMAGE_MODEL=gpt-image-2
AAP_AI_IMAGE_QUALITY=low
AAP_AI_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
# auto requests provider timestamps first and estimates them locally when the
# selected compatible STT endpoint only returns plain text.
AAP_AI_TRANSCRIPTION_TIMESTAMP_MODE=auto
AAP_AI_AUDIO_CHUNK_SECONDS=2700
AAP_AI_TIMESTAMP_FALLBACK_CHUNK_SECONDS=300
AAP_AI_CLIP_SEGMENTS_PER_BATCH=160
# Retry only explicit temporary provider failures. Ambiguous request timeouts
# are never retried automatically to avoid duplicate paid generations.
AAP_AI_RETRY_ATTEMPTS=3
AAP_AI_RETRY_BASE_SECONDS=0.75
YT_LOADER_RETENTION_HOURS=24
YT_LOADER_AFTER_DOWNLOAD_MINUTES=15
YT_LOADER_READY_HOURS=24
